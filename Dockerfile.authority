FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY tsconfig.json ./
COPY contracts/ ./contracts/
COPY artifacts/ ./artifacts/
COPY authority-node/ ./authority-node/
COPY scripts/ ./scripts/            

# Compile TypeScript
RUN npx tsc --project tsconfig.json || true

ENTRYPOINT ["node", "--experimental-vm-modules", "dist/authority-node/src/index.js"]