FROM node:22-alpine

WORKDIR /app

# Install dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY tsconfig.json ./
COPY artifacts/ ./artifacts/
COPY client/ ./client/

# Compile TypeScript
RUN npx tsc --project tsconfig.json || true

ENTRYPOINT ["sh", "-c", "node dist/client/scenarios/${SCENARIO:-full-lifecycle}.js"]